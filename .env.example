# ============================================================
# SubReader Backend Configuration
# ============================================================
# Copy this file to `.env` and modify as needed:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------
# Required. Database connection string.
# SQLite (default, auto-creates the db file):
DATABASE_URL=sqlite:./subreader.db?mode=rwc
# Note: Only SQLite is currently supported.

# Connection pool minimum size (default: 5)
# DB_POOL_MIN=5

# Connection pool maximum size (default: 50)
# DB_POOL_MAX=50

# ------------------------------------------------------------
# Authentication / JWT
# ------------------------------------------------------------
# Required. Secret key used to sign JWT tokens.
# ⚠️  Change this to a strong random string in production!
JWT_SECRET=change-me-to-a-random-secret

# Access token expiry in seconds (default: 3600 = 1 hour)
# ACCESS_TOKEN_EXPIRY_SECS=3600

# Refresh token expiry in seconds (default: 2592000 = 30 days)
# REFRESH_TOKEN_EXPIRY_SECS=2592000

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
# Listen address and port (default: 0.0.0.0:8080)
# LISTEN_ADDR=0.0.0.0:8080

# ------------------------------------------------------------
# File Storage
# ------------------------------------------------------------
# Root directory for uploaded files (default: ./storage)
# STORAGE_PATH=./storage

# ------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ------------------------------------------------------------
# Comma-separated list of allowed origins (default: localhost dev origins)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
# Log level filter (default: info)
# Options: trace, debug, info, warn, error
# RUST_LOG=info
